# --- LLM Provider (required) ---
LLM_PROVIDER=anthropic              # "anthropic" or "openai"
LLM_MODEL=claude-sonnet-4-6
LLM_LIGHT_MODEL=claude-haiku-4-5

# --- API Key ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# --- Pipeline settings (optional, shown with defaults) ---
MAX_PAGES=7
CONCURRENCY=10
MAX_TOKENS=1024
TIMEOUT=90

# --- Paper fetching (optional, for --fetch-papers) ---
CROSSREF_EMAIL=your@email.edu
